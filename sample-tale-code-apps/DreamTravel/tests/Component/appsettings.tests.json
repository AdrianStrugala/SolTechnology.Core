{
  "Authentication": {
    "ApiKey": "<SECRET>"
  },
  "HttpPolicy": {
    "// Component-test profile": "Tighten every Polly knob so an unreachable upstream (e.g. WireMock not yet up) fails fast instead of waiting out production timeouts. Body capture is on for richer assertion messages.",
    "RequestTimeout": 2000,
    "MaxRequestRetries": 1,
    "RetryInitialDelay": 25,
    "RetryTimeout": 200,
    "CircuitBreakerMinimumThroughput": 2,
    "CircuitBreakerSamplingDuration": 2000,
    "CircuitBreakerDelayDuration": 1000,
    "IncludeResponseBodyInException": true
  },
  "HTTPClients": {
    "Aiia": {
      "BaseAddress": "https://api-sandbox.aiia.eu",
      "Headers": [
        {
          "Name": "Authorization",
          "Value": ""
        }
      ]
    },
    "Google": {
      "BaseAddress": "http://localhost:2137/google/",
      "Options": {
        "Key": "googleKey"
      }
    },
    "Michelin": {
      "BaseAddress": "http://apir.viamichelin.com",
      "Options": {
        "Key": ""
      }
    },
    "GeoDb": {
      "BaseAddress": "http://geodb-free-service.wirefreethought.com"
    }
  }
}
