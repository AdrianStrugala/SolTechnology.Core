<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <Version>0.7.0</Version>
        <Description>Story Framework - Unified workflow orchestration for multi-step business processes. Supports both simple automated chains and pausable workflows with persistence. Features Tale Code philosophy with StoryHandler, Chapters, and Context for readable, maintainable business logic.</Description>
        <PackageTags>sol technology core story workflow chain pausable state-machine saga orchestration sqlite async dotnet business-process tale-code</PackageTags>
        <Product>SolTechnology.Core.Story</Product>
        <PackageId>SolTechnology.Core.Story</PackageId>
        <AssemblyName>SolTechnology.Core.Story</AssemblyName>
        <RootNamespace>SolTechnology.Core.Story</RootNamespace>

        <PackageIcon>docs\mini-logo.png</PackageIcon>
        <PackageReadmeFile>docs\readme.md</PackageReadmeFile>
        <RepositoryUrl>https://github.com/AdrianStrugala/SolTechnology.Core</RepositoryUrl>
    </PropertyGroup>

    <ItemGroup>
        <None Include="..\..\docs\mini-logo.png" Pack="true" Visible="false" PackagePath="docs\mini-logo.png" />
        <None Include="..\..\docs\Story.md" Pack="true" Visible="false" PackagePath="docs\readme.md" />
    </ItemGroup>

    <ItemGroup>
        <!--
            FrameworkReference replaces a stale Microsoft.AspNetCore.Mvc.Core 2.2.5 PackageReference
            that pulled System.Text.Encodings.Web 4.5.0 (CVE-2021-26701, Critical) into the graph.
            Story only uses stock MVC controller types (ControllerBase, [HttpGet/Post], IActionResult,
            [FromRoute/Body/Header]) which all live in the ASP.NET Core shared framework. Same
            approach as SolTechnology.Core.Logging.
        -->
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
        <PackageReference Include="Microsoft.Data.Sqlite.Core" Version="10.0.9" />
        <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
        <PackageReference Include="SQLitePCLRaw.bundle_green" Version="2.1.11" />

        <!--
            CVE-2025-6965 (GHSA-2m69-gcr7-jv3q): SQLite < 3.50.2 memory corruption, reached
            transitively via Microsoft.Data.Sqlite.Core -> SQLitePCLRaw.bundle_green ->
            SQLitePCLRaw.lib.e_sqlite3 2.1.11. No patched SQLitePCLRaw release exists yet
            (2.1.11 is the latest on nuget.org as of 2026-06). SQLite is an opt-in,
            non-default Story persistence provider (in-memory is the default), so the blast
            radius is limited to apps that explicitly call UseSqliteStoryRepository(...).
            Suppress this single advisory only — audit stays active for every other package.
            REMOVE once SQLitePCLRaw ships a bundle on SQLite >= 3.50.2.
        -->
        <NuGetAuditSuppress Include="https://github.com/advisories/GHSA-2m69-gcr7-jv3q" />

        <!--
            Microsoft.Extensions.* PackageReferences inherited from src/Directory.Build.props
            are already provided by the shared framework. Removing them here mirrors the
            SolTechnology.Core.Logging setup and keeps the package graph clean.
        -->
        <PackageReference Remove="Microsoft.Extensions.Configuration" />
        <PackageReference Remove="Microsoft.Extensions.Configuration.Binder" />
        <PackageReference Remove="Microsoft.Extensions.DependencyInjection" />
        <PackageReference Remove="Microsoft.Extensions.Options" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\SolTechnology.Core.AUID\SolTechnology.Core.AUID.csproj" />
      <ProjectReference Include="..\SolTechnology.Core\SolTechnology.Core.csproj" />
    </ItemGroup>

</Project>
