<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Version>0.7.0</Version>
		<Description>Resilient HTTP client wrapper with built-in retry policies, exponential backoff, circuit breaker (Microsoft.Extensions.Http.Resilience / Polly v8), correlation propagation, idempotent-only retry by default, opt-in response-body capture, ValidateOnStart configuration, and first-class metrics on the 'SolTechnology.Core.HTTP' meter.</Description>
		<PackageTags>sol technology core httpclient rest api polly retry resilience circuit-breaker avro http dotnet metrics opentelemetry</PackageTags>
		<Product>SolTechnology.Core.HTTP</Product>
		<PackageId>SolTechnology.Core.HTTP</PackageId>
		<AssemblyName>SolTechnology.Core.HTTP</AssemblyName>

		<PackageIcon>docs\mini-logo.png</PackageIcon>
		<PackageReadmeFile>docs\readme.md</PackageReadmeFile>
		<RepositoryUrl>https://github.com/AdrianStrugala/SolTechnology.Core</RepositoryUrl>
	</PropertyGroup>
	<ItemGroup>
		<None Include="..\..\docs\mini-logo.png" Pack="true" Visible="false" PackagePath="docs\mini-logo.png" />
		<None Include="..\..\docs\Clients.md" Pack="true" Visible="false" PackagePath="docs\readme.md" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="AvroConvert" Version="3.4.16" />
		<PackageReference Include="Microsoft.Extensions.Http.Resilience" Version="10.7.0" />
		<PackageReference Include="Polly" Version="8.7.0" />
		<!--
			JetBrains.Annotations supplies the [MustDisposeResource] attribute
			used on RequestBuilder's raw-response verbs. PrivateAssets="all"
			keeps the dependency out of the consumer's package graph — Rider /
			ReSharper / JetBrains analysers still pick up the annotation
			from our assembly metadata.
		-->
		<PackageReference Include="JetBrains.Annotations" Version="2026.2.0" PrivateAssets="all" />
	</ItemGroup>

	<!--
		Core.HTTP propagates correlation onto outbound requests by reading the
		ambient ICorrelationIdService that Core.Logging owns. Pulling the project
		reference also transitively requires the ASP.NET Core shared framework
		because Core.Logging targets it (Microsoft.AspNetCore.App) — declare it
		explicitly so the package graph is well-formed and Microsoft.Extensions.*
		PackageReferences inherited from src/Directory.Build.props get pruned by
		NuGet (avoiding the override block we maintained for Resilience).
	-->
	<ItemGroup>
		<FrameworkReference Include="Microsoft.AspNetCore.App" />
		<ProjectReference Include="..\SolTechnology.Core\SolTechnology.Core.csproj" />
		<ProjectReference Include="..\SolTechnology.Core.Logging\SolTechnology.Core.Logging.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Remove="Microsoft.Extensions.Configuration" />
		<PackageReference Remove="Microsoft.Extensions.Configuration.Binder" />
		<PackageReference Remove="Microsoft.Extensions.DependencyInjection" />
		<PackageReference Remove="Microsoft.Extensions.Options" />
	</ItemGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="SolTechnology.Core.HTTP.Tests" />
	</ItemGroup>

</Project>
