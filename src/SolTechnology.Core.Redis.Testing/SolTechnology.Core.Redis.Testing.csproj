<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Description>Integration-test your Redis-backed caching against a real Redis instance. A Testcontainers-backed RedisFixture exposes HostName (host:port) and a StackExchange.Redis connection string, with a FlushAsync() reset between tests and a shared-container reuse model. Reference from test projects only; not needed at runtime in production assemblies.</Description>
		<PackageTags>soltechnology core redis testing testcontainers cache stackexchange-redis emulator integration-tests component-tests dotnet csharp</PackageTags>
		<Product>SolTechnology.Core.Redis.Testing</Product>
		<Title>SolTechnology.Core Redis Testing</Title>
		<PackageId>SolTechnology.Core.Redis.Testing</PackageId>
		<AssemblyName>SolTechnology.Core.Redis.Testing</AssemblyName>

		<PackageReadmeSource>Redis.Testing.md</PackageReadmeSource>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\SolTechnology.Core.Testing\SolTechnology.Core.Testing.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Testcontainers.Redis" Version="4.12.0" />
		<PackageReference Include="StackExchange.Redis" Version="3.0.0" />
	</ItemGroup>

</Project>

