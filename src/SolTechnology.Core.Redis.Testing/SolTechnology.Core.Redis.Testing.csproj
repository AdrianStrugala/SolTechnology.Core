<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Version>0.1.0</Version>
		<Description>Integration-testing fixture for SolTechnology.Core.Cache / Redis consumers — a Testcontainers-backed RedisFixture exposing HostName (host:port) and a StackExchange.Redis connection string, with a FlushAsync() between-test reset and the shared container reuse model. Reference from test projects only; not needed at runtime in production assemblies.</Description>
		<PackageTags>sol technology core redis testing testcontainers cache integration-tests component-tests</PackageTags>
		<Product>SolTechnology.Core.Redis.Testing</Product>
		<PackageId>SolTechnology.Core.Redis.Testing</PackageId>
		<AssemblyName>SolTechnology.Core.Redis.Testing</AssemblyName>

		<PackageIcon>docs\mini-logo.png</PackageIcon>
		<PackageReadmeFile>docs\readme.md</PackageReadmeFile>
		<RepositoryUrl>https://github.com/AdrianStrugala/SolTechnology.Core</RepositoryUrl>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\..\docs\mini-logo.png" Pack="true" Visible="false" PackagePath="docs\mini-logo.png" />
		<None Include="..\..\docs\Redis.Testing.md" Pack="true" Visible="false" PackagePath="docs\readme.md" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SolTechnology.Core.Testing\SolTechnology.Core.Testing.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Testcontainers.Redis" Version="4.12.0" />
		<PackageReference Include="StackExchange.Redis" Version="3.0.0" />
	</ItemGroup>

</Project>

