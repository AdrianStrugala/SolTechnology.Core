<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Version>0.1.0</Version>
		<Description>Hangfire-backed persistent event dispatch and recurring jobs for SolTechnology.Core.CQRS. Opt in with AddPersistentEvents() — events survive process restarts via Hangfire storage.</Description>
		<PackageTags>sol technology core hangfire persistent-events background-jobs recurring-jobs cqrs dotnet</PackageTags>
		<Product>SolTechnology.Core.Hangfire</Product>
		<PackageId>SolTechnology.Core.Hangfire</PackageId>
		<AssemblyName>SolTechnology.Core.Hangfire</AssemblyName>

		<PackageReadmeSource>Hangfire.md</PackageReadmeSource>
	</PropertyGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="SolTechnology.Core.Hangfire.Tests" />
	</ItemGroup>

	<ItemGroup>
		<!-- Hangfire.Core pulls Newtonsoft.Json >= 11.0.1 (CVE-2024-21907 / NU1903). Pin to 13.0.4. -->
		<PackageReference Include="Hangfire.Core" Version="1.8.23" />
		<PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.9" />
		<PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SolTechnology.Core\SolTechnology.Core.csproj" />
		<ProjectReference Include="..\SolTechnology.Core.CQRS\SolTechnology.Core.CQRS.csproj" />
		<ProjectReference Include="..\SolTechnology.Core.Logging\SolTechnology.Core.Logging.csproj" />
	</ItemGroup>

</Project>



