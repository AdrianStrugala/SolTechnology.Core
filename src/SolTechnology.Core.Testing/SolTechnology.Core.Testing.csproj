<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Description>Foundation NUnit testing helpers for SolTechnology.Core consumers: AutoFixture data attributes (NSubstitute-based), optional Bogus customizations for realistic data, a Retry helper for eventual-consistency assertions, a shared Testcontainers lifetime/reuse model (TESTCONTAINERS_REUSE, restart-if-stopped, readiness probes) and Serilog in-memory log assertions. Reference from test projects only; not needed at runtime in production assemblies.</Description>
		<PackageTags>soltechnology core testing nunit autofixture nsubstitute bogus testcontainers unit-tests integration-tests component-tests dotnet csharp</PackageTags>
		<Product>SolTechnology.Core.Testing</Product>
		<Title>SolTechnology.Core Testing</Title>
		<PackageId>SolTechnology.Core.Testing</PackageId>
		<AssemblyName>SolTechnology.Core.Testing</AssemblyName>

		<PackageReadmeSource>Testing.md</PackageReadmeSource>
	</PropertyGroup>

	<ItemGroup>
		<!-- NUnit + AutoFixture data attributes. NSubstitute (not Moq) per the repo anti-stack
		     in package-management/references/canonical-versions.md. -->
		<PackageReference Include="NUnit" Version="4.6.1" />
		<PackageReference Include="AutoFixture" Version="4.18.1" />
		<PackageReference Include="AutoFixture.AutoNSubstitute" Version="4.18.1" />
		<PackageReference Include="AutoFixture.NUnit4" Version="4.19.0" />
		<PackageReference Include="NSubstitute" Version="5.3.0" />
		<PackageReference Include="FluentAssertions" Version="7.2.2" />
		<PackageReference Include="Bogus" Version="35.6.5" />
		<PackageReference Include="Testcontainers" Version="4.12.0" />

		<!-- In-memory Serilog sink for log assertions. -->
		<PackageReference Include="Serilog.Sinks.InMemory" Version="2.0.0" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\SolTechnology.Core\SolTechnology.Core.csproj" />
	</ItemGroup>

</Project>





