<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Description>Integration-test your data layer against real MSSQL and PostgreSQL databases. A Testcontainers-backed SQLFixture with pluggable schema provisioning (dacpac / raw scripts / delegate, e.g. EF migrations) and Respawn-based reset. ORM-agnostic — serves Dapper and EF alike. Reference from test projects only; not needed at runtime in production assemblies.</Description>
		<PackageTags>soltechnology core sql testing testcontainers mssql sqlserver postgres postgresql dacpac respawn integration-tests component-tests dotnet csharp</PackageTags>
		<Product>SolTechnology.Core.SQL.Testing</Product>
		<Title>SolTechnology.Core SQL Testing</Title>
		<PackageId>SolTechnology.Core.SQL.Testing</PackageId>
		<AssemblyName>SolTechnology.Core.SQL.Testing</AssemblyName>

		<PackageReadmeSource>SQL.Testing.md</PackageReadmeSource>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\SolTechnology.Core.Testing\SolTechnology.Core.Testing.csproj" />
	</ItemGroup>

	<ItemGroup>
		<!-- MSSQL uses the generic ContainerBuilder + host-side login probe (NOT Testcontainers.MsSql:
		     azure-sql-edge lacks sqlcmd, which breaks its built-in wait). Postgres uses the dedicated builder. -->
		<PackageReference Include="Testcontainers" Version="4.12.0" />
		<PackageReference Include="Testcontainers.PostgreSql" Version="4.12.0" />
		<PackageReference Include="Microsoft.SqlServer.DacFx" Version="170.4.83" />
		<PackageReference Include="Microsoft.Data.SqlClient" Version="7.0.1" />
		<PackageReference Include="Npgsql" Version="10.0.3" />
		<PackageReference Include="Respawn" Version="7.0.0" />
	</ItemGroup>

</Project>



