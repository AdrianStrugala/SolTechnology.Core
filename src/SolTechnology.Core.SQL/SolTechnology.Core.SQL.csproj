<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Version>0.6.0</Version>
		<TreatWarningsAsErrors>false</TreatWarningsAsErrors>
		<Description>SQL Server database access layer with Dapper and Entity Framework support, and Polly resilience policies. Includes DacFx for database deployment and schema management in CI/CD pipelines. Integration-test fixtures moved to the companion package SolTechnology.Core.SQL.Testing.</Description>
		<PackageTags>sol technology core sql database dapper entity-framework polly resilience dacpac sqlserver dotnet orm</PackageTags>
		<Product>SolTechnology.Core.SQL</Product>
		<PackageId>SolTechnology.Core.SQL</PackageId>
		<AssemblyName>SolTechnology.Core.SQL</AssemblyName>

		<PackageIcon>docs\mini-logo.png</PackageIcon>
		<PackageReadmeFile>docs\readme.md</PackageReadmeFile>
		<RepositoryUrl>https://github.com/AdrianStrugala/SolTechnology.Core</RepositoryUrl>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\..\docs\mini-logo.png" Pack="true" Visible="false" PackagePath="docs\mini-logo.png" />
		<None Include="..\..\docs\SQL.md" Pack="true" Visible="false" PackagePath="docs\readme.md" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Data.SqlClient" Version="7.0.1" />
		<PackageReference Include="Microsoft.SqlServer.DacFx" Version="170.4.83" />
		<PackageReference Include="Polly" Version="8.7.0" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SolTechnology.Core\SolTechnology.Core.csproj" />
	</ItemGroup>

</Project>
