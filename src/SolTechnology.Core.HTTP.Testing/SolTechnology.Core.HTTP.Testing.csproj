<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Description>Mock external HTTP APIs in your tests with zero ceremony. A WireMock.Net-backed WireMockFixture plus a fluent fake-API DSL (Fake&lt;TClient&gt;().WithRequest(...).WithResponse(...)) keyed off your generated HTTP client interfaces. Reference from test projects only; not needed at runtime in production assemblies.</Description>
		<PackageTags>soltechnology core http testing wiremock mock stub fake-api integration-tests component-tests dotnet csharp</PackageTags>
		<Product>SolTechnology.Core.HTTP.Testing</Product>
		<Title>SolTechnology.Core HTTP Testing</Title>
		<PackageId>SolTechnology.Core.HTTP.Testing</PackageId>
		<AssemblyName>SolTechnology.Core.HTTP.Testing</AssemblyName>

		<PackageReadmeSource>HTTP.Testing.md</PackageReadmeSource>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\SolTechnology.Core.Testing\SolTechnology.Core.Testing.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="WireMock.Net" Version="2.11.0" />
		<PackageReference Include="WireMock.Net.StandAlone" Version="2.11.0" />
	</ItemGroup>

</Project>
