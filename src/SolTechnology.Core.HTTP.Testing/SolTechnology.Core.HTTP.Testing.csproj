<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Version>0.1.0</Version>
		<Description>Integration-testing fixtures for SolTechnology.Core.HTTP consumers — a WireMock.Net-backed WireMockFixture and a fluent fake-API DSL (Fake&lt;TClient&gt;().WithRequest(...).WithResponse(...)) keyed off your generated HTTP client interfaces. Reference from test projects only; not needed at runtime in production assemblies.</Description>
		<PackageTags>sol technology core http testing wiremock mock fake-api integration-tests component-tests</PackageTags>
		<Product>SolTechnology.Core.HTTP.Testing</Product>
		<PackageId>SolTechnology.Core.HTTP.Testing</PackageId>
		<AssemblyName>SolTechnology.Core.HTTP.Testing</AssemblyName>

		<PackageIcon>docs\mini-logo.png</PackageIcon>
		<PackageReadmeFile>docs\readme.md</PackageReadmeFile>
		<RepositoryUrl>https://github.com/AdrianStrugala/SolTechnology.Core</RepositoryUrl>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\..\docs\mini-logo.png" Pack="true" Visible="false" PackagePath="docs\mini-logo.png" />
		<None Include="..\..\docs\HTTP.Testing.md" Pack="true" Visible="false" PackagePath="docs\readme.md" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SolTechnology.Core.Testing\SolTechnology.Core.Testing.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="WireMock.Net" Version="1.6.8" />
		<PackageReference Include="WireMock.Net.StandAlone" Version="1.6.8" />
		<!-- CVE-2024-51417 (GHSA-4cv2-4hjh-77rx, HIGH): WireMock.Net drags the vulnerable
		     System.Linq.Dynamic.Core 1.3.12 transitively. Pin up to the patched 1.6.0. Not used
		     directly in source — this reference exists solely to override the transitive. -->
		<PackageReference Include="System.Linq.Dynamic.Core" Version="1.6.0" />
	</ItemGroup>

</Project>
