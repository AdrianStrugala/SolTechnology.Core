<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Description>Integration-test your Azure Service Bus messaging against the official emulator. A Testcontainers-backed ServiceBusFixture runs the emulator (which manages its own backing MSSQL sidecar) with an AMQP readiness probe and stable-name reuse. Reference from test projects only; not needed at runtime in production assemblies.</Description>
		<PackageTags>soltechnology core azure servicebus testing testcontainers emulator amqp messaging integration-tests component-tests dotnet csharp</PackageTags>
		<Product>SolTechnology.Core.ServiceBus.Testing</Product>
		<Title>SolTechnology.Core Service Bus Testing</Title>
		<PackageId>SolTechnology.Core.ServiceBus.Testing</PackageId>
		<AssemblyName>SolTechnology.Core.ServiceBus.Testing</AssemblyName>

		<PackageReadmeSource>ServiceBus.Testing.md</PackageReadmeSource>
	</PropertyGroup>

	<ItemGroup>
		<!-- The bundled default emulator topology, read back at runtime and bind-mounted into the container. -->
		<EmbeddedResource Include="servicebus-emulator-config.json" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SolTechnology.Core.Testing\SolTechnology.Core.Testing.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Testcontainers.ServiceBus" Version="4.12.0" />
	</ItemGroup>

</Project>

